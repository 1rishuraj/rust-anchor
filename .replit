entrypoint = "index.ts"

hidden = [".config", "bun.lock"]
modules = ["bun-1.2"]

[nix]
channel = "stable-24_11"

[deployment]
build = ["sh", "-c", "bun build --target=bun --outdir=dist index.ts"]
run = ["bun", "dist/index.js"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 3000
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Tests"

[[workflows.workflow]]
name = "Run Tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bun test double.test.ts"

[workflows.workflow.metadata]
outputType = "console"
